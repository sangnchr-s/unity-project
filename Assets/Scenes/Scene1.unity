--- !u!114 &281000223
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 281000220}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5f7201a12d95ffc409449d95f23cf332, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 0.95, g: 0.95, b: 0.95, a: 1}
  m_RaycastTarget: 0
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 10102, guid: 0000000000000000e000000000000000, type: 0}
    m_FontSize: 22
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 10
    m_MaxSize: 40
    m_Alignment: 4
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 1
    m_LineSpacing: 1.08
  m_Text: "\u041F\u0440\u0430\u0432\u0438\u043B\u0430 \u0440\u0430\u0431\u043E\u0442\u044B
    \u0441 \u0441\u0438\u043C\u0443\u043B\u044F\u0442\u043E\u0440\u043E\u043C \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0438\n\n\u2022
    \u0421\u043B\u0435\u0434\u0443\u0439\u0442\u0435 \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044E
    , \u0437\u0430\u0434\u0430\u043D\u043D\u043E\u043C\u0443  \u0432 \u0441\u0446\u0435\u043D\u0435
    (\u043A\u043B\u0430\u0432\u0438\u0448\u0438 \u0438 \u043F\u043E\u0434\u0441\u043A\u0430\u0437\u043A\u0438
    \u043D\u0430 \u044D\u043A\u0440\u0430\u043D\u0435).\n\u2022 \u041F\u0435\u0440\u0435\u0434 
    \u0431\u0443\u0440\u0435\u043D\u0438\u0435\u043C \u043F\u043E\u0434\u0432\u0435\u0434\u0438\u0442\u0435
    \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0443 \u043A \u0437\u0430\u0431\u043E\u044E;
    \u043D\u0435 \u043D\u0430\u0447\u0438\u043D\u0430\u0439\u0442\u0435 \u0431\u0443\u0440\u0435\u043D\u0438\u0435
    \u043F\u0440\u0438 \u043D\u0435\u043A\u043E\u0440\u0440\u0435\u043A\u0442\u043D\u043E\u043C
    \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0438 \u0431\u0443\u0440\u0430.\n\u2022
    \u041F\u0435\u0440\u0435\u0445\u043E\u0434\u0438\u0442\u0435 \u043F\u043B\u0430\u0432\u043D\u043E,
    \u0438\u0437\u0431\u0435\u0433\u0430\u0439\u0442\u0435 \u0440\u0435\u0437\u043A\u0438\u0445
    \u0441 \u0442\u043E\u043B\u043A\u043D\u043E\u0432\u0435\u043D\u0438\u0439  \u0441
    \u043F\u043E\u0440\u043E\u0434\u043E\u0439 \u0438  \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u0430\u043C\u0438
    \u0432\u044B\u0440\u0430\u0431\u043E\u0442\u043A\u0438.\n\u2022  \u041F\u0440\u0438
    \u0441\u0431\u043E\u0435 \u043F\u0435\u0440\u0435\u0437\u0430\u043F\u0443\u0441\u0442\u0438\u0442\u0435
    \u0441\u0446\u0435\u043D\u0443\n\n\u041F\u043E\u0434 \u0440\u043E\u0431\u043D\u043E\u0441\u0442\u0438
    \u0432 \u043C \u0435\u0442\u043E\u0434\u0438\u0447\u043A\u0435 \u0434\u0438\u0441
    \u0446\u0438\u043F\u043B\u0438\u043D\u044B."
